# Application
APP_NAME=Attendify
DEBUG=False

# Security
SECRET_KEY=change-this-to-a-random-32-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql://attendify:attendify@localhost:5432/attendify

# CORS (comma-separated or update config.py list)
# ALLOWED_ORIGINS=http://localhost:5173

# ML Service
ML_SERVICE_URL=http://localhost:8001
ML_SERVICE_ENABLED=False
FACE_SIMILARITY_THRESHOLD=0.60

# QR
QR_TOKEN_EXPIRE_MINUTES=15
QR_RENEWAL_INTERVAL_SECONDS=60

# File Storage
UPLOAD_DIR=uploads
MAX_FACE_PHOTOS=10
MIN_FACE_PHOTOS=1
